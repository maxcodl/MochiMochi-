<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="?attr/colorOnSurface"
            tools:title="Sticker Pack Details" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/metadata_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/preview_side_margin"
        android:layout_marginBottom="24dp"
        android:paddingVertical="8dp">


        <ImageView
            android:id="@+id/tray_image"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/tray_image_content_description"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@mipmap/ic_launcher_round" />

        <TextView
            android:id="@+id/pack_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/pack_size"
            app:layout_constraintStart_toEndOf="@+id/tray_image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Pusheen the Cat" />

        <TextView
            android:id="@+id/author_prefix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="by"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@+id/pack_name"
            app:layout_constraintStart_toEndOf="@+id/pack_name"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBaselineOf="@+id/pack_name"
            app:layout_constraintStart_toEndOf="@+id/author_prefix"
            tools:text="petellison" />

        <ImageView
            android:id="@+id/sticker_pack_animation_indicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="6dp"
            android:contentDescription="@string/sticker_pack_animation_indicator"
            android:src="@drawable/animated_pack_indicator"
            app:layout_constraintBottom_toBottomOf="@+id/pack_name"
            app:layout_constraintStart_toEndOf="@+id/author"
            app:layout_constraintTop_toTopOf="@+id/pack_name"
            app:tint="?attr/colorOnSurfaceVariant"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/pack_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/pack_name"
            app:layout_constraintTop_toBottomOf="@+id/pack_name"
            tools:text="1.2 MB" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.kawai.mochi.BottomFadingRecyclerView
            android:id="@+id/sticker_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:contentDescription="@string/stickers_label"
            android:fadingEdgeLength="@dimen/fading_edge_length"
            android:paddingHorizontal="@dimen/preview_side_margin"
            android:requiresFadingEdge="vertical"
            tools:listitem="@layout/sticker_packs_list_image_item" />

        <View
            android:id="@+id/expanded_sticker_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:visibility="invisible" />

        <androidx.cardview.widget.CardView
            android:id="@+id/expanded_sticker_card"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="invisible"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="12dp"
            app:cardElevation="16dp"
            app:contentPadding="16dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.facebook.drawee.view.SimpleDraweeView
                    android:id="@+id/sticker_details_expanded_sticker"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    tools:src="@mipmap/ic_launcher_round" />

                <TextView
                    android:id="@+id/expanded_sticker_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="sticker.webp" />

                <TextView
                    android:id="@+id/expanded_sticker_emojis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    tools:text="😀👍" />

                <TextView
                    android:id="@+id/expanded_sticker_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    tools:text="45 KB" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/edit_emoji_button"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/edit_emojis_title"
                        android:gravity="center"
                        android:text="@string/edit_button"
                        android:textSize="12sp"
                        app:icon="@drawable/sticker_3rdparty_info"
                        app:iconGravity="textStart"
                        app:iconSize="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/delete_sticker_button"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/remove_sticker"
                        android:gravity="center"
                        android:text="@string/delete_button"
                        android:textColor="?attr/colorError"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_trash_can"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="?attr/colorError" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.1"
            android:background="?attr/colorOutlineVariant"
            android:visibility="invisible"
            tools:visibility="visible" />

    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/preview_side_margin"
        android:minHeight="60dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/already_added_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/details_pack_already_added"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/edit_pack_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/edit_pack_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/edit_pack"
            android:text="@string/edit_button"
            app:layout_constraintBottom_toTopOf="@id/add_to_whatsapp_button"
            app:layout_constraintEnd_toStartOf="@+id/delete_pack_button"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_max="160dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/delete_pack_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/delete_pack_title"
            android:text="@string/delete_button"
            android:textColor="?attr/colorError"
            app:layout_constraintBottom_toTopOf="@id/add_to_whatsapp_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/edit_pack_button"
            app:layout_constraintWidth_max="160dp"
            app:strokeColor="?attr/colorError" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_to_whatsapp_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textAllCaps="true"
            android:textStyle="bold"
            app:icon="@drawable/sticker_3rdparty_wa"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:layout_constraintBottom_toTopOf="@id/sticker_pack_details_tap_to_preview"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_max="320dp"
            android:text="@string/add_to_whatsapp" />

        <TextView
            android:id="@+id/sticker_pack_details_tap_to_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/sticker_pack_details_tap_to_preview"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
