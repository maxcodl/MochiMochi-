<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings_title"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationContentDescription="@string/abc_action_bar_up_description"
            app:navigationIconTint="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="start">

            <!-- Sticker Folder Section -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_sticker_folder_label" />

            <TextView
                android:id="@+id/current_folder_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="?attr/colorSurfaceVariant"
                android:layout_marginBottom="12dp"
                tools:text="Default (internal storage)" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/choose_folder_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_choose_folder"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_to_default_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_reset_to_default"
                android:layout_marginBottom="24dp" />

            <!-- Theme Section -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_theme_label" />

            <RadioGroup
                android:id="@+id/theme_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/theme_light"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_light"
                    android:paddingVertical="8dp" />

                <RadioButton
                    android:id="@+id/theme_dark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_dark"
                    android:paddingVertical="8dp" />

                <RadioButton
                    android:id="@+id/theme_amoled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_amoled"
                    android:paddingVertical="8dp" />

                <RadioButton
                    android:id="@+id/theme_system"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_system"
                    android:paddingVertical="8dp"
                    android:checked="true" />
            </RadioGroup>

            <!-- Animation Toggle Section -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_performance_label" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/enable_animations_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/settings_enable_animations"
                android:layout_marginBottom="24dp"
                tools:checked="true" />

            <!-- Import Behaviour -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_import_behaviour_label" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/ask_pack_picker_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="@string/settings_ask_pack_picker"
                android:layout_marginBottom="24dp"
                tools:checked="false" />

            <!-- Telegram Import Section -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_telegram_import_label" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/telegram_bot_token_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/telegram_bot_token_not_configured"
                android:layout_marginBottom="24dp" />

            <!-- Diagnostics Section -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_diagnostics_label" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/run_diagnostics_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_run_diagnostics"
                android:layout_marginBottom="24dp" />

            <!-- About Section -->
            <TextView
                style="@style/SettingsHeaderStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_label" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_app_name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_about_author"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/github_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_github_button"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/telegram_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_telegram_button"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/donate_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_donate_button" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
