# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
env/
venv/
.venv/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Telethon session files — contain auth tokens, NEVER commit
*.session
*.session-journal

# ─── Bot Runtime Data ─────────────────────────────────────────────────────────
# Written at runtime, not source code
authorized_chats.json

# Generated sticker output (large binaries built at runtime)
wasticker_packs/

# Scratch / working copies
*copy*.py

# ─── Android (Gradle) ─────────────────────────────────────────────────────────
# Gradle caches
Android/.gradle/
Android/build/
Android/app/build/

# Auto-generated build log
Android/build_latest.txt

# Local SDK/NDK path — machine-specific, never commit
Android/local.properties

# IntelliJ module descriptor files (auto-regenerated by Gradle sync)
*.iml

# Compiled outputs
*.apk
*.aab
*.ipa
*.dex

# Keystore / signing keys — never commit private keys
*.jks
*.keystore

# ─── IDE — VS Code ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# ─── IDE — IntelliJ / Android Studio ─────────────────────────────────────────
# Keep misc.xml (SDK version) and modules.xml (project structure)
# Ignore user-specific state
.idea/workspace.xml
.idea/tasks.xml
.idea/caches/
.idea/shelf/
.idea/studiobot.xml
.idea/deviceManager.xml
.idea/dictionaries/
.idea/dynamic.xml
.idea/
.vscode/
Android/.idea
Android/.idea/workspace.xml
Android/.idea/tasks.xml
Android/.idea/caches/
Android/.idea/shelf/
Android/.idea/studiobot.xml
Android/.idea/deviceManager.xml
Android/.idea/dictionaries/

# ─── Misc ─────────────────────────────────────────────────────────────────────
node_modules/
coverage/
dist/
out/
*.tsbuildinfo
DerivedData/
keystore_base64.txt
